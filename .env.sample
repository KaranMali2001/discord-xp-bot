# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=                      # bot token
DISCORD_CLIENT_ID=                  # application id (slash cmds + OAuth)
DISCORD_CLIENT_SECRET=              # dashboard "Login with Discord" OAuth (blank locally = dev-login)
DISCORD_GUILD_ID=                   # test server id (guild cmds = instant)

# ── Database ──────────────────────────────────────────────
DATABASE_URL=file:./dev.db          # sqlite for dev; postgres url later

# ── API / Dashboard ───────────────────────────────────────
API_PORT=8080
WEB_URL=http://localhost:5173       # dashboard origin (CORS + OAuth redirect)
SESSION_SECRET=change-me-32-chars-minimum-secret

# ── Tuning ────────────────────────────────────────────────
XP_TICK_SECONDS=60                  # voice award interval; set 2 locally to see fast
LOG_LEVEL=info
