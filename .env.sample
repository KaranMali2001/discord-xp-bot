# ── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=                      # bot token
DISCORD_CLIENT_ID=                  # application id (slash cmds + OAuth)
DISCORD_CLIENT_SECRET=              # dashboard "Login with Discord" OAuth (blank locally = dev-login)
DISCORD_GUILD_ID=                   # test server id (guild cmds = instant)

# ── Database (Postgres) ───────────────────────────────────
# dev: local Docker Postgres. prod: Neon POOLED URL (must include ?sslmode=require — SSL is
# enforced in code for any remote host).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/xp
# Direct (non-pooled) URL for drizzle-kit migrations; blank = same as DATABASE_URL (local). prod:
# Neon DIRECT URL (pgBouncer drops the sessions the migrator needs).
DATABASE_DIRECT_URL=

# ── Config/events cache invalidation (§2.1) ───────────────
# The bot serves guild config/events from memory (Neon scales to zero when idle); the API pings
# the bot after each write. Loopback + a shared secret keep the endpoint off-box.
CACHE_INVALIDATE_HOST=127.0.0.1     # bot: interface to bind the invalidate listener on
CACHE_INVALIDATE_PORT=8091          # bot: listener port / api: target port
CACHE_INVALIDATE_SECRET=            # shared secret; blank = no auth (fine on a single local box)
BOT_INTERNAL_URL=http://127.0.0.1:8091  # api: where to reach the bot; blank = disable (backstop only)

# ── Cloudinary (ticket-attachment image storage; optional) ─
CLOUDINARY_CLOUD_NAME=              # required only when ticket image capture is enabled
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── API / Dashboard ───────────────────────────────────────
API_PORT=8080
PUBLIC_API_URL=                     # prod: public API origin for OAuth redirect (e.g. https://api.yourdomain.com); blank = localhost
WEB_URL=http://localhost:5173       # dashboard origin (CORS + OAuth redirect)
SESSION_SECRET=change-me-32-chars-minimum-secret
AUTH_DISABLED=false                 # local only: set true to view/edit the dashboard without logging in

# ── Tuning ────────────────────────────────────────────────
XP_TICK_SECONDS=60                  # voice award interval; set 2 locally to see fast
LOG_LEVEL=info
LOG_DIR=                            # set to persist logs to a file (Docker: /data/logs bind-mount); blank = stdout only

# ── Transcription (Part 1: capture + store) ───────────────
TRANSCRIPTS_ENABLED=false           # true = record each speaker's audio during captures/events → transcript_jobs
AUDIO_ROOT=./data/audio             # where WAVs + sidecar JSON land (Docker: /data/audio on a mounted volume)
