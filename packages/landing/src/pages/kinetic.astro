---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import Avatar from '../components/Avatar.astro';
import SessionShot from '../components/SessionShot.astro';
import SignupForm from '../components/SignupForm.astro';
import { site, crew, sessions, nextSession } from '../data/site';

// Mock-interview loop, stated plainly. Big type carries it, copy stays terse.
const rounds = [
  { k: 'BOOK', t: 'Take a slot', d: 'Open the sheet. Pick a Friday. No screen, no gate.' },
  { k: 'RUN', t: 'Sit the round', d: 'Forty-five minutes. DSA or system design. Real pressure.' },
  { k: 'KEEP', t: 'Get the tape', d: 'Written notes by the weekend. The recording is yours.' },
];
---

<Base title="Kinetic">
  <a href="/" class="back">&#8592; all concepts</a>

  <main class="kx">
    <!-- HERO: oversized typographic statement -->
    <section id="hero" class="hero">
      <header class="hero__meta">
        <Logo size={22} />
        <span class="hero__freq">{site.station}</span>
      </header>

      <h1 class="hero__type" aria-label="We talk code, every friday.">
        <span class="hero__line" style="--i:0">WE</span>
        <span class="hero__line" style="--i:1">TALK</span>
        <span class="hero__line hero__line--accent" style="--i:2">CODE</span>
        <span class="hero__small" style="--i:3">every friday</span>
      </h1>

      <footer class="hero__foot">
        <p class="mono hero__tag">{site.cadence} &#183; since {site.since}</p>
        <a href="#join" class="hero__cta">
          Join the room
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg>
        </a>
      </footer>
    </section>

    <!-- CREW: names as type -->
    <section id="crew" class="stmt stmt--left">
      <aside class="stmt__aside">
        <p class="mono stmt__label">01 &#8212; the crew</p>
        <p class="stmt__note">A small desk keeps the frequency alive. Engineers who ship, hosting for people who want to.</p>
      </aside>
      <ul class="roster">
        {crew.map((m, i) => (
          <li class="roster__row" style={`--i:${i}`}>
            <span class="roster__pic"><Avatar name={m.name} initials={m.initials} tint="var(--accent)" ratio={1} /></span>
            <span class="roster__name">{m.name}</span>
            <span class="mono roster__role">{m.role}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- FRIDAY SESSIONS: big type list, hover reveals detail -->
    <section id="sessions" class="stmt stmt--right">
      <aside class="stmt__aside">
        <p class="mono stmt__label">02 &#8212; fridays</p>
        <p class="stmt__note">One topic. Forty-five minutes. Live and unscripted &#8212; internals, systems, the messy real stuff. Recording by Monday.</p>
      </aside>
      <ul class="list">
        {sessions.map((s, i) => (
          <li class:list={['list__row', i === 0 && 'is-next']} style={`--i:${i}`}>
            <a class="list__link" href="#archive">
              <span class="list__bar" aria-hidden="true"></span>
              <span class="mono list__ep">EP.{s.ep}</span>
              <span class="list__title">{s.title}</span>
              <span class="list__reveal">
                <span class="mono list__topic">{s.topic}</span>
                <time class="mono list__date" datetime={s.iso}>{i === 0 ? 'up next' : s.date}</time>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- MOCK INTERVIEWS -->
    <section id="mock" class="stmt stmt--left">
      <aside class="stmt__aside">
        <p class="mono stmt__label">03 &#8212; mock interviews</p>
        <p class="stmt__note">Make the real one feel like a rerun. Three moves, run by people who have sat the loop.</p>
      </aside>
      <ol class="rounds">
        {rounds.map((r, i) => (
          <li class="rounds__row" style={`--i:${i}`}>
            <span class="mono rounds__k">{r.k}</span>
            <span class="rounds__t">{r.t}</span>
            <span class="rounds__d">{r.d}</span>
          </li>
        ))}
      </ol>
    </section>

    <!-- ARCHIVE -->
    <section id="archive" class="stmt stmt--right">
      <aside class="stmt__aside">
        <p class="mono stmt__label">04 &#8212; archive</p>
        <p class="stmt__note">A recent night, mid-flight. EP.{nextSession.ep} &#8212; {nextSession.title}. Nothing said on Friday gets lost.</p>
      </aside>
      <div class="archive">
        <p class="archive__big">ON<br />THE<br /><span class="archive__accent">RECORD</span></p>
        <div class="archive__shot"><SessionShot /></div>
      </div>
    </section>

    <!-- JOIN -->
    <section id="join" class="join">
      <p class="mono stmt__label">05 &#8212; join</p>
      <h2 class="join__type">DON&#8217;T<br />MISS A<br /><span class="join__accent">FRIDAY</span></h2>
      <p class="stmt__note join__note">One quiet reminder before we go live. That&#8217;s the whole deal.</p>
      <SignupForm cta="Join" />
    </section>
  </main>

  <footer class="foot">
    <Logo size={20} />
    <span class="mono">{site.cadence}</span>
    <a class="mono" href={site.xUrl}>{site.handle}</a>
  </footer>
</Base>

<style is:global>
  :root {
    --bg: #0b0b0c;
    --surface: #131315;
    --surface-2: #1a1a1c;
    --text: #f4f4f2;
    --muted: #7a7a7e;
    --border: rgba(255, 255, 255, 0.1);
    --accent: #ffe14d;
    --accent-2: #ffe14d;
    --accent-ink: #0b0b0c;
    --live: #ff5a36;
    --radius: 6px;
    --font-display: var(--font-geist);
    --font-mono: var(--font-geist-mono);
  }
  body { background: var(--bg); color: var(--text); }

  /* Static fallback everywhere. Motion only opts in below, gated so text is
     never left invisible on unsupported browsers or with reduced motion. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      /* section-level rise */
      .stmt, .join {
        opacity: 0;
        transform: translateY(26px);
        animation: kx-rise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 18%;
      }
      @keyframes kx-rise { to { opacity: 1; transform: none; } }

      /* scroll-driven type morph: big statement type tightens + scales as it
         enters view. transform + letter-spacing only. */
      .stmt__big, .archive__big, .join__type, .hero__type {
        animation: kx-morph linear both;
        animation-timeline: view();
        animation-range: entry 5% cover 45%;
      }
      @keyframes kx-morph {
        from { transform: scale(0.92); letter-spacing: 0.02em; }
        to { transform: none; letter-spacing: -0.045em; }
      }
    }
  }
</style>

<style>
  .mono {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .back {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 80;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    background: color-mix(in srgb, var(--surface) 80%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
  }
  .back:hover { color: var(--accent); }

  .kx { overflow: clip; }

  /* ---------- HERO ---------- */
  .hero {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.4rem, 4vw, 2.6rem) clamp(1.2rem, 5vw, 4rem);
  }
  .hero__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .hero__freq {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hero__type {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin: 0;
    padding: clamp(1rem, 3vw, 2.4rem) 0;
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 0.86;
    text-transform: uppercase;
    transform-origin: left center;
  }
  .hero__line {
    display: block;
    font-size: clamp(3rem, 14vw, 12rem);
  }
  .hero__line--accent { color: var(--accent); }
  .hero__small {
    display: block;
    margin-top: clamp(0.6rem, 1.6vw, 1.2rem);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: clamp(0.8rem, 1.6vw, 1.05rem);
    letter-spacing: 0.24em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .hero__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
  }
  .hero__tag { color: var(--muted); }
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ink);
    background: var(--accent);
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), filter 0.2s ease;
  }
  .hero__cta svg { transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1); }
  .hero__cta:hover { filter: brightness(1.06); }
  .hero__cta:hover svg { transform: translateX(4px); }

  /* Staggered reveal of the hero lines (independent of section rise). */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .hero__line, .hero__small {
        opacity: 0;
        transform: translateY(0.18em);
        animation: kx-drop 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        animation-delay: calc(var(--i) * 70ms + 80ms);
      }
      @keyframes kx-drop { to { opacity: 1; transform: none; } }
    }
  }

  /* ---------- SHARED STATEMENT SECTION ---------- */
  .stmt {
    max-width: 1400px;
    margin: 0 auto;
    padding: clamp(4rem, 12vw, 9rem) clamp(1.2rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  .stmt--left { grid-template-columns: minmax(0, 1fr); text-align: left; }
  .stmt--right { grid-template-columns: minmax(0, 1fr); text-align: left; }
  .stmt__aside { max-width: 42ch; }
  .stmt__label { color: var(--accent); }
  .stmt__note {
    margin-top: 0.9rem;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    color: var(--muted);
  }
  /* Right-aligned rhythm on wider screens. */
  @media (min-width: 780px) {
    .stmt--right { justify-items: end; text-align: right; }
    .stmt--right .stmt__aside { margin-left: auto; }
  }

  /* ---------- CREW: names as type ---------- */
  .roster { list-style: none; margin: 0; padding: 0; width: 100%; }
  .roster__row {
    display: grid;
    grid-template-columns: clamp(52px, 6vw, 84px) 1fr auto;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.4rem);
    padding: clamp(1rem, 2.5vw, 1.9rem) 0;
    border-top: 1px solid var(--border);
  }
  .roster__row:last-child { border-bottom: 1px solid var(--border); }
  .roster__pic {
    width: clamp(52px, 6vw, 84px);
    --avatar-radius: 50%;
    transform: scale(0.86);
    opacity: 0.72;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
    will-change: transform;
  }
  .roster__name {
    font-size: clamp(1.6rem, 5.5vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.98;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
    transform-origin: left center;
  }
  .roster__role { color: var(--muted); text-align: right; }
  .roster__row:hover .roster__pic { transform: scale(1.15); opacity: 1; }
  .roster__row:hover .roster__name { color: var(--accent); transform: translateX(0.4rem); }
  .roster__row:hover .roster__role { color: var(--accent); }
  @media (max-width: 560px) {
    .roster__row { grid-template-columns: 44px 1fr; }
    .roster__role { grid-column: 2; text-align: left; }
  }

  /* ---------- FRIDAY SESSIONS: big type list ---------- */
  .list { list-style: none; margin: 0; padding: 0; width: 100%; }
  .list__row { border-top: 1px solid var(--border); }
  .list__row:last-child { border-bottom: 1px solid var(--border); }
  .list__link {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: clamp(0.8rem, 2.5vw, 2rem);
    padding: clamp(1rem, 2.6vw, 2rem) 0 clamp(1rem, 2.6vw, 2rem) 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .list__bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .list__ep { color: var(--muted); }
  .list__title {
    font-size: clamp(1.5rem, 5vw, 3.6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s ease;
    transform-origin: left center;
  }
  .list__reveal {
    display: inline-flex;
    align-items: baseline;
    gap: clamp(0.8rem, 2vw, 1.6rem);
    opacity: 0;
    transform: translateX(0.6rem);
    transition: opacity 0.35s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .list__date { color: var(--accent); }
  .list__row.is-next .list__title { color: var(--accent); }
  .list__row.is-next .list__reveal { opacity: 1; transform: none; }
  .list__link:hover, .list__link:focus-visible {
    transform: translateX(clamp(0.4rem, 1.5vw, 1.2rem));
    outline: none;
  }
  .list__link:hover .list__bar,
  .list__link:focus-visible .list__bar { transform: scaleY(1); }
  .list__link:hover .list__title,
  .list__link:focus-visible .list__title { color: var(--accent); }
  .list__link:hover .list__reveal,
  .list__link:focus-visible .list__reveal { opacity: 1; transform: none; }
  @media (max-width: 620px) {
    .list__reveal { display: none; }
    .list__row.is-next .list__reveal { display: inline-flex; }
  }

  /* ---------- MOCK INTERVIEWS ---------- */
  .rounds { list-style: none; margin: 0; padding: 0; width: 100%; }
  .rounds__row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    grid-template-areas: 'k t' 'k d';
    column-gap: clamp(1rem, 3vw, 2.4rem);
    row-gap: 0.4rem;
    padding: clamp(1.4rem, 3vw, 2.4rem) 0;
    border-top: 1px solid var(--border);
  }
  .rounds__row:last-child { border-bottom: 1px solid var(--border); }
  .rounds__k { grid-area: k; color: var(--accent); padding-top: 0.5rem; }
  .rounds__t {
    grid-area: t;
    font-size: clamp(1.5rem, 4.5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1;
  }
  .rounds__d {
    grid-area: d;
    max-width: 48ch;
    color: var(--muted);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    line-height: 1.55;
  }
  @media (max-width: 560px) {
    .rounds__row { grid-template-columns: 1fr; grid-template-areas: 'k' 't' 'd'; }
    .rounds__k { padding-top: 0; }
  }

  /* ---------- ARCHIVE ---------- */
  .archive {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .archive__big {
    margin: 0;
    font-weight: 700;
    font-size: clamp(3rem, 12vw, 9rem);
    letter-spacing: -0.045em;
    line-height: 0.86;
    text-transform: uppercase;
    transform-origin: left center;
  }
  .archive__accent { color: var(--accent); }
  .archive__shot { max-width: 640px; width: 100%; }
  @media (min-width: 880px) {
    .archive { grid-template-columns: auto minmax(0, 1fr); }
    .stmt--right .archive__big { text-align: left; }
  }

  /* ---------- JOIN ---------- */
  .join {
    max-width: 1400px;
    margin: 0 auto;
    padding: clamp(4rem, 12vw, 9rem) clamp(1.2rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
  }
  .join__type {
    margin: 0.9rem 0 0;
    font-weight: 700;
    font-size: clamp(3rem, 13vw, 11rem);
    letter-spacing: -0.045em;
    line-height: 0.84;
    text-transform: uppercase;
    transform-origin: left center;
  }
  .join__accent { color: var(--accent); }
  .join__note { margin-top: 1.6rem; margin-bottom: 2.2rem; max-width: 44ch; }

  /* ---------- FOOTER ---------- */
  .foot {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding: 2.5rem clamp(1.2rem, 5vw, 4rem) 5rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
  }
  .foot .mono { font-size: 0.74rem; }
  .foot a:hover { color: var(--accent); }
</style>
