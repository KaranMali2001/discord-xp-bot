---
import { site } from '../data/site'
import Base from '../layouts/Base.astro'
import CrewOrbitSection from '../components/CrewOrbitSection'
import { AudioCarousel } from '../signal/AudioCarousel'
import { LiveMic } from '../signal/LiveMic'
import '../signal/signal.css'

const signalBarHalf = Array.from({ length: 20 }, (_, index) => ({
  base: (0.2 + ((index * 5) % 8) * 0.085).toFixed(2),
  peak: (0.38 + ((index * 3) % 6) * 0.105).toFixed(2),
}))
const signalBars = [...signalBarHalf, ...signalBarHalf.slice().reverse()].map((bar, index) => ({ ...bar, index }))
const applicationUrl = 'https://t.co/Tvx2yICikK'
const applicationsPaused = true
---

<Base
  title="Signal Room"
  description="Tech Talks is a beginner-friendly developer community for Friday discussions, mock interviews and shared reading."
>
  <script is:inline>
    (() => {
      const saved = localStorage.getItem('tech-talks-theme');
      const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = saved || (dark ? 'dark' : 'light');
    })();
  </script>

  <a class="skip-link" href="#main-content">Skip to content</a>

  <aside class="signal-head" aria-label="Tech Talks is on air">
    <span class="signal-head__status"><i aria-hidden="true"></i>ON AIR</span>
    <span class="signal-head__episode">Friday discussion: WebSockets, SSE and the live web</span>
    <span class="signal-head__meter" aria-hidden="true">
      {signalBars.map((bar) => <i style={`--bar:${bar.index}; --scale:${bar.base}; --peak:${bar.peak}`}></i>)}
    </span>
    <span class="signal-head__time">38:24 / 42:00</span>
  </aside>

  <main id="main-content" class="signal-page">
    <nav class="frequency-nav" aria-label="Primary navigation">
      <a href="#top" class="frequency-nav__brand" aria-label="Tech Talks home">
        <img src="/signal/tech-talks-mark-v2.png" alt="" width="56" height="56" />
        <span>TECH TALKS</span>
      </a>

      <div class="frequency-nav__links">
        <a href="#team">Team</a>
        <a href="#events">Events</a>
        <a href={site.xUrl} target="_blank" rel="noreferrer">X</a>
      </div>

      <div class="frequency-nav__actions">
        <a class="island-button island-button--small" href={applicationUrl} data-application-link={applicationsPaused ? '' : undefined} aria-haspopup={applicationsPaused ? 'dialog' : undefined}>
          <span>Join the community</span><i aria-hidden="true">↗</i>
        </a>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
          <span class="theme-toggle__light" aria-hidden="true">☀</span>
          <span class="theme-toggle__dark" aria-hidden="true">☽</span>
        </button>
        <button class="menu-toggle" type="button" data-menu-toggle aria-label="Open navigation" aria-expanded="false">
          <span></span><span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" data-mobile-menu role="dialog" aria-modal="true" aria-label="Mobile navigation" aria-hidden="true">
      <div class="mobile-menu__links">
        <a href="#team">Meet the team</a>
        <a href="#events">Events</a>
        <a href={site.xUrl} target="_blank" rel="noreferrer">Follow on X</a>
        <a href={applicationUrl} data-application-link={applicationsPaused ? '' : undefined} aria-haspopup={applicationsPaused ? 'dialog' : undefined}>Join the community</a>
      </div>
    </div>

    <section id="top" class="signal-hero">
      <div class="hero-wave" aria-hidden="true">
        <svg viewBox="0 0 900 320" preserveAspectRatio="none">
          <defs>
            <linearGradient id="heroSignalGradient" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="var(--signal-violet)"></stop>
              <stop offset="0.28" stop-color="var(--signal-blue)"></stop>
              <stop offset="0.5" stop-color="var(--signal-accent-bright)"></stop>
              <stop offset="0.72" stop-color="var(--signal-blue)"></stop>
              <stop offset="1" stop-color="var(--signal-violet)"></stop>
            </linearGradient>
          </defs>
          <g class="hero-wave__signal">
            <path
              class="hero-wave__glow"
              pathLength="100"
              d="M0 160 C70 160 80 160 120 160 C150 160 158 118 190 118 C222 118 230 202 266 202 C304 202 312 76 350 76 C388 76 396 244 450 244 C504 244 512 76 550 76 C588 76 596 202 634 202 C670 202 678 118 710 118 C742 118 750 160 780 160 C820 160 830 160 900 160"
            ></path>
            <path
              class="hero-wave__line"
              pathLength="100"
              d="M0 160 C70 160 80 160 120 160 C150 160 158 118 190 118 C222 118 230 202 266 202 C304 202 312 76 350 76 C388 76 396 244 450 244 C504 244 512 76 550 76 C588 76 596 202 634 202 C670 202 678 118 710 118 C742 118 750 160 780 160 C820 160 830 160 900 160"
            ></path>
            <path
              class="hero-wave__current"
              pathLength="100"
              d="M0 160 C70 160 80 160 120 160 C150 160 158 118 190 118 C222 118 230 202 266 202 C304 202 312 76 350 76 C388 76 396 244 450 244 C504 244 512 76 550 76 C588 76 596 202 634 202 C670 202 678 118 710 118 C742 118 750 160 780 160 C820 160 830 160 900 160"
            ></path>
          </g>
        </svg>
      </div>

      <div class="signal-hero__copy reveal-block">
        <h1>Learn out loud.<br /><span>Grow in good company.</span></h1>
        <p>A beginner-friendly tech community for conversations, mock interviews and shared reading that help you move faster.</p>
        <div class="signal-hero__actions">
          <a class="island-button" href={applicationUrl} data-application-link={applicationsPaused ? '' : undefined} aria-haspopup={applicationsPaused ? 'dialog' : undefined}>
            <span>Join the community</span><i aria-hidden="true">↗</i>
          </a>
          <a class="text-link" href="#events">Explore the room</a>
        </div>
      </div>

      <div class="signal-hero__studio reveal-block">
        <LiveMic client:load />
      </div>

      <p class="signal-hero__frequency" aria-hidden="true">FRIDAY FREQUENCY 88.7</p>
    </section>

    <section class="team-section section-shell reveal-block">
      <div id="team" class="section-heading section-heading--center">
        <h2>Every voice shapes the room.</h2>
        <p>Hover or focus a signal to meet the people who keep each conversation welcoming and useful.</p>
      </div>
      <CrewOrbitSection client:visible />
    </section>

    <section class="events-section section-shell reveal-block">
      <div id="events" class="section-heading">
        <p class="section-kicker">What happens here</p>
        <h2>Three ways to get better together.</h2>
      </div>

      <div class="event-bento">
        <article class="bezel event-card event-card--friday">
          <span class="event-card__spotlight" aria-hidden="true"><i></i></span>
          <div class="bezel__core">
            <div class="event-card__illustration" aria-hidden="true">
              <svg viewBox="0 0 680 440" role="presentation">
                <g class="event-card__diagram-signal">
                  <path d="M122 188c54-50 118-76 194-78 83-2 160 24 232 78"></path>
                  <path d="M154 190c48-34 105-51 170-51 70 0 136 17 198 51"></path>
                </g>
                <g class="event-card__diagram-ui">
                  <rect x="74" y="66" width="114" height="68" rx="18"></rect>
                  <path d="M102 103h10l9-18 12 34 11-25 9 9h9"></path>
                  <rect x="250" y="44" width="180" height="98" rx="18"></rect>
                  <path d="M282 78h116M282 104h76M282 124h48"></path>
                  <path d="M488 72h112a16 16 0 0 1 16 16v48a16 16 0 0 1-16 16h-44l-28 24v-24h-40a16 16 0 0 1-16-16V88a16 16 0 0 1 16-16Z"></path>
                  <path d="M500 106h84M500 128h54"></path>
                </g>
                <g class="event-card__diagram-people">
                  <circle cx="154" cy="238" r="25"></circle>
                  <circle cx="276" cy="214" r="26"></circle>
                  <circle cx="404" cy="214" r="26"></circle>
                  <circle cx="526" cy="238" r="25"></circle>
                  <path d="M102 344c4-58 18-88 52-88 25 0 42 16 49 48M222 344c3-72 18-108 54-108 37 0 52 36 55 108M349 344c3-72 18-108 55-108 36 0 51 36 54 108M477 304c8-32 24-48 49-48 34 0 48 30 52 88"></path>
                  <path d="M154 282c29 3 54 15 77 35M526 282c-29 3-54 15-77 35"></path>
                  <path d="M276 276c19 18 40 28 64 28s45-10 64-28"></path>
                  <path d="M242 306l-36-24M438 306l36-24"></path>
                </g>
                <g class="event-card__diagram-table">
                  <path d="M72 344h536l-46 52H118Z"></path>
                  <path d="M248 344l18-56h78l18 56M276 316h58"></path>
                  <path d="M390 344l14-44h62l14 44"></path>
                  <path d="M206 344v-28M194 316h24M198 304h16"></path>
                  <circle cx="206" cy="298" r="8"></circle>
                </g>
              </svg>
            </div>
            <div class="event-card__copy">
              <span>Every Friday</span>
              <h3>Friday discussions</h3>
              <p>One technical question, unpacked by people at different stages of the same journey.</p>
              <a href="#listen">Hear a session <i aria-hidden="true">↘</i></a>
            </div>
          </div>
        </article>

        <article class="bezel event-card event-card--mock">
          <span class="event-card__spotlight" aria-hidden="true"><i></i></span>
          <div class="bezel__core">
            <div class="event-card__interview" aria-hidden="true">
              <i class="event-card__interview-person event-card__interview-person--left"></i>
              <span class="event-card__interview-turn"><b></b></span>
              <i class="event-card__interview-person event-card__interview-person--right"></i>
              <span class="event-card__interview-prompt"></span>
              <span class="event-card__interview-response"></span>
            </div>
            <div class="event-card__copy">
              <span>Now refining</span>
              <h3>Mock interviews</h3>
              <p>Practice live. Leave with a useful debrief.</p>
            </div>
          </div>
        </article>

        <article class="bezel event-card event-card--reading">
          <span class="event-card__spotlight" aria-hidden="true"><i></i></span>
          <div class="bezel__core">
            <div class="reading-stack" aria-hidden="true">
              <i><span></span><span></span><span></span><span></span></i>
              <i><span></span><span></span><span></span><span></span></i>
              <i><span></span><span></span><span></span><span></span></i>
            </div>
            <div class="event-card__copy">
              <span>Starting next</span>
              <h3>Blog reading</h3>
              <p>Read one strong article. Compare notes and keep what matters.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="listen-section section-shell reveal-block">
      <div id="listen" class="section-heading">
        <p class="section-kicker">Friday recordings</p>
        <h2>Press play. Join the circle.</h2>
        <p>Move between WebSockets, Redis, frontend and networking conversations without leaving the room.</p>
      </div>
      <AudioCarousel client:visible />
    </section>

    <section class="contribute-section section-shell reveal-block">
      <div class="contribute-section__spectrum" aria-hidden="true">
        <svg viewBox="0 0 1200 260" preserveAspectRatio="none">
          <defs>
            <linearGradient id="ctaSignalGradient" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="var(--signal-violet)"></stop>
              <stop offset="0.34" stop-color="var(--signal-blue)"></stop>
              <stop offset="0.5" stop-color="var(--signal-accent-bright)"></stop>
              <stop offset="0.66" stop-color="var(--signal-blue)"></stop>
              <stop offset="1" stop-color="var(--signal-violet)"></stop>
            </linearGradient>
          </defs>
          <g class="contribute-section__spectrum-lines">
            <path pathLength="100" d="M0 130 C100 130 120 130 170 130 C220 130 226 92 276 92 C326 92 334 178 390 178 C446 178 456 48 520 48 C566 48 574 212 600 212 C626 212 634 48 680 48 C744 48 754 178 810 178 C866 178 874 92 924 92 C974 92 980 130 1030 130 C1080 130 1100 130 1200 130"></path>
            <path pathLength="100" d="M0 130 C100 130 120 130 170 130 C220 130 226 92 276 92 C326 92 334 178 390 178 C446 178 456 48 520 48 C566 48 574 212 600 212 C626 212 634 48 680 48 C744 48 754 178 810 178 C866 178 874 92 924 92 C974 92 980 130 1030 130 C1080 130 1100 130 1200 130"></path>
            <path pathLength="100" d="M0 130 C100 130 120 130 170 130 C220 130 226 92 276 92 C326 92 334 178 390 178 C446 178 456 48 520 48 C566 48 574 212 600 212 C626 212 634 48 680 48 C744 48 754 178 810 178 C866 178 874 92 924 92 C974 92 980 130 1030 130 C1080 130 1100 130 1200 130"></path>
          </g>
        </svg>
      </div>
      <div id="contribute" class="contribute-section__copy">
        <h2>Bring the next question.</h2>
        <p>Join the room, suggest a Friday topic or help turn a community idea into a session.</p>
        <a class="island-button contribute-section__cta" href={applicationUrl} data-application-link={applicationsPaused ? '' : undefined} aria-haspopup={applicationsPaused ? 'dialog' : undefined}>
          <span>Join the community</span><i aria-hidden="true">↗</i>
        </a>
      </div>
    </section>

    <footer class="signal-footer">
      <div class="signal-footer__brand">
        <img src="/signal/tech-talks-mark-v2.png" alt="" width="70" height="70" />
        <div>
          <strong>TECH TALKS</strong>
          <p>Beginners connect here, learn together and grow faster.</p>
        </div>
      </div>
      <div class="signal-footer__console" aria-label="Tech Talks sign off">
        <span>Fri · 10:30 PM IST</span>
        <div class="signal-footer__dial" aria-hidden="true"><i></i></div>
        <a class="signal-footer__x" href={site.xUrl} target="_blank" rel="noreferrer">
          <i aria-hidden="true">X</i><span>Follow {site.handle}</span>
        </a>
      </div>
      <p class="signal-footer__signoff">Mic down. Questions stay open.</p>
    </footer>
  </main>

  <dialog class="application-dialog" data-application-dialog aria-labelledby="application-dialog-title">
    <div class="application-dialog__panel">
      <form method="dialog">
        <button class="application-dialog__close" type="submit" aria-label="Close applications update">×</button>
      </form>
      <p class="section-kicker">Community update</p>
      <h2 id="application-dialog-title">Applications are coming back soon.</h2>
      <p>We have temporarily halted new applications while we prepare the next community intake. We’ll reopen the same form soon.</p>
      <div class="application-dialog__actions">
        <a class="text-link" href={site.xUrl} target="_blank" rel="noreferrer">Follow updates on X</a>
        <form method="dialog"><button class="island-button" type="submit"><span>Got it</span><i aria-hidden="true">✓</i></button></form>
      </div>
    </div>
  </dialog>

  <div class="signal-grain" aria-hidden="true"></div>

  <script>
    const root = document.documentElement;
    const themeToggle = document.querySelector('[data-theme-toggle]');
    const menuToggle = document.querySelector('[data-menu-toggle]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    const applicationDialog = document.querySelector('[data-application-dialog]');

    themeToggle?.addEventListener('click', () => {
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      localStorage.setItem('tech-talks-theme', next);
    });

    const closeMenu = () => {
      menuToggle?.setAttribute('aria-expanded', 'false');
      menuToggle?.setAttribute('aria-label', 'Open navigation');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('menu-open');
    };

    menuToggle?.addEventListener('click', () => {
      const open = menuToggle.getAttribute('aria-expanded') !== 'true';
      menuToggle.setAttribute('aria-expanded', String(open));
      menuToggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
      mobileMenu?.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('menu-open', open);
    });

    mobileMenu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    document.querySelectorAll('[data-application-link]').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        closeMenu();
        if (applicationDialog instanceof HTMLDialogElement) applicationDialog.showModal();
      });
    });

    applicationDialog?.addEventListener('click', (event) => {
      if (event.target === applicationDialog && applicationDialog instanceof HTMLDialogElement) applicationDialog.close();
    });

    if (
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      const cards = Array.from(document.querySelectorAll('.event-card')).flatMap((card) => {
        const spotlight = card.querySelector('.event-card__spotlight');
        const light = spotlight?.querySelector('i');
        return card instanceof HTMLElement && spotlight instanceof HTMLElement && light instanceof HTMLElement
          ? [{ card, spotlight, light }]
          : [];
      });
      let frame = 0;
      let pointerX = -999;
      let pointerY = -999;

      const renderSpotlights = () => {
        cards.forEach(({ card, spotlight, light }) => {
          const bounds = card.getBoundingClientRect();
          const nearby =
            pointerX >= bounds.left - 24 && pointerX <= bounds.right + 24 &&
            pointerY >= bounds.top - 24 && pointerY <= bounds.bottom + 24;

          spotlight.style.opacity = nearby ? '1' : '0';
          if (!nearby) return;

          const x = Math.max(0, Math.min(bounds.width, pointerX - bounds.left));
          const y = Math.max(0, Math.min(bounds.height, pointerY - bounds.top));
          light.style.transform = `translate3d(${x - 90}px, ${y - 90}px, 0)`;
        });
        frame = 0;
      };

      document.addEventListener('pointermove', (event) => {
        pointerX = event.clientX;
        pointerY = event.clientY;
        if (!frame) frame = window.requestAnimationFrame(renderSpotlights);
      });
    }

    window.addEventListener(
      'load',
      () => {
        if (!window.location.hash) return;
        document.getElementById(window.location.hash.slice(1))?.scrollIntoView({ block: 'start' });
      },
      { once: true },
    );
  </script>
</Base>
