---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import Waveform from '../components/Waveform.astro';
import SessionShot from '../components/SessionShot.astro';
import SignupForm from '../components/SignupForm.astro';
import CrewOrbitSection from '../components/CrewOrbitSection';
import { site, sessions, nextSession, contributions } from '../data/site';

const steps = [
  { n: '01', t: 'Book a slot', d: 'Grab an open time on the sheet. No résumé screen, no gatekeeping.' },
  { n: '02', t: 'Sit the round', d: '45 minutes of real pressure — DSA or system design with someone who has run the loop.' },
  { n: '03', t: 'Get the tape', d: 'Written notes the same weekend, plus the recording of your own thinking.' },
];

---

<Base title="Broadcast">
  <a href="/" class="back">← all concepts</a>

  <!-- ON AIR bar (from After Hours) -->
  <aside class="nowbar">
    <span class="nowbar__on"><span class="nowbar__dot"></span>ON AIR</span>
    <Waveform bars={16} class="nowbar__wave" />
    <span class="nowbar__title">EP.{nextSession.ep} — {nextSession.title}</span>
    <a href="#join" class="nowbar__cta">tune in</a>
  </aside>

  <main id="top" class="bc">
    <!-- HERO -->
    <section class="hero">
      <div class="stars" aria-hidden="true"></div>
      <header class="hero__nav">
        <Logo size={26} />
        <span class="hero__freq">{site.station}</span>
      </header>
      <div class="hero__center">
        <p class="hero__kick">broadcasting every friday night · since {site.since}</p>
        <h1 class="hero__title">The mic's warm.<br /><em>Pull up a chair.</em></h1>
        <p class="hero__sub">{site.blurb}</p>
        <div class="hero__actions">
          <a href="#join" class="btn btn--solid">Tune in</a>
          <a href="#sessions" class="btn btn--ghost">See the sessions</a>
        </div>
        <div class="hero__dial" aria-hidden="true">
          <span class="hero__dialknob"></span>
        </div>
      </div>
      <div class="hero__marquee" aria-hidden="true">
        <div class="hero__mtrack">
          {[...sessions, ...sessions].map((s) => (<span>{s.title}<b>·</b></span>))}
        </div>
      </div>
    </section>

    <div class="bc__wrap">
      <!-- CONSTELLATION / CREW with social popovers -->
      <section id="crew" class="block reveal">
        <p class="eyebrow">+ the constellation</p>
        <h2 class="block__h">A small crew keeps the lights on. <em>Say hi.</em></h2>
        <p class="block__lead">
          Five people who love this stuff enough to show up every Friday. Tap anyone to find them.
        </p>

        <CrewOrbitSection client:only="react" />
      </section>

      <!-- FRIDAY SESSIONS (Kinetic big list) -->
      <section id="sessions" class="block sess reveal">
        <div class="sess__head">
          <p class="eyebrow">02 — fridays</p>
          <p class="sess__note">One topic. Forty-five minutes. Live and unscripted — internals, systems, the messy real stuff. Recording by Monday.</p>
        </div>
        <ol class="sesslist">
          {sessions.map((s, i) => (
            <li class:list={['sessrow', i === 0 && 'is-next']}>
              <span class="sessrow__ep">EP.{s.ep}</span>
              <span class="sessrow__title">{s.title}</span>
              <span class="sessrow__meta">
                <span class="sessrow__topic">{s.topic}</span>
                <span class="sessrow__tag">{i === 0 ? 'up next' : s.date}</span>
              </span>
            </li>
          ))}
        </ol>
      </section>

      <!-- MOCK INTERVIEWS -->
      <section id="mock" class="block reveal">
        <p class="eyebrow">the hot seat · mock interviews</p>
        <h2 class="block__h">Make the real interview feel like a rerun.</h2>
        <ol class="steps">
          {steps.map((s) => (
            <li><span class="steps__n">{s.n}</span><div><h3>{s.t}</h3><p>{s.d}</p></div></li>
          ))}
        </ol>
      </section>

      <!-- COMMUNITY CONTRIBUTIONS -->
      <section id="contributions" class="block reveal">
        <p class="eyebrow">+ from the community</p>
        <h2 class="block__h">What the crew ships between Fridays.</h2>
        <p class="block__lead">Blogs, videos, talks, and open repos — the community keeps building out loud.</p>
        <ul class="contrib">
          {contributions.map((c) => (
            <li class="contrib__card">
              <a href={c.href} class="contrib__link">
                <span class="contrib__top">
                  <span class:list={['contrib__type', `is-${c.type.toLowerCase()}`]}>{c.type}</span>
                  <time class="contrib__date" datetime={c.iso}>{c.date}</time>
                </span>
                <h3 class="contrib__title">{c.title}</h3>
                <p class="contrib__blurb">{c.blurb}</p>
                <span class="contrib__by">{c.author}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <!-- FROM THE ARCHIVE (kept as-is) -->
    <div class="bc__wrap">
      <section id="archive" class="block reveal">
        <p class="eyebrow">+ from the archive</p>
        <h2 class="block__h">A recent night, mid-flight.</h2>
        <p class="block__lead">Missed a Friday? Every session is saved and re-runnable. Here's one from the booth.</p>
        <div class="proof"><SessionShot /><p class="proof__cap">Placeholder screenshot — EP.{nextSession.ep}, {nextSession.title}.</p></div>
      </section>

      <!-- JOIN -->
      <section id="join" class="block join">
        <p class="eyebrow"><span class="nowbar__dot"></span>tune in</p>
        <h2 class="join__h">Don't miss a Friday.</h2>
        <p class="block__lead">One quiet reminder before we go live. That's the whole deal.</p>
        <SignupForm cta="Tune in" />
      </section>
    </div>
  </main>

  <footer class="foot"><Logo size={22} /><span>{site.cadence}</span><a href={site.xUrl}>{site.handle}</a></footer>
  <div class="grain" aria-hidden="true"></div>
</Base>

<style is:global>
  :root {
    /* cosmic — richer but controlled: deep violet scene, one warm-gold accent */
    --bg: #0c0920;
    --surface: #181334;
    --surface-2: #221a44;
    --text: #f3edff;
    --muted: #a99cc9;
    --border: rgba(236, 232, 255, 0.13);
    --accent: #f5b038;      /* warm gold — primary accent */
    --accent-2: #f2789f;    /* rose — secondary, sparing */
    --accent-ink: #160f26;
    --live: #6fd8ec;        /* cyan signal */
    --radius: 16px;
    --font-display: var(--font-geist);
    --font-mono: var(--font-geist-mono);
  }
  body {
    background:
      radial-gradient(72% 55% at 85% -6%, rgba(242, 120, 159, 0.22), transparent 55%),
      radial-gradient(66% 60% at 4% 6%, rgba(120, 96, 236, 0.30), transparent 55%),
      radial-gradient(60% 52% at 58% 110%, rgba(64, 120, 224, 0.18), transparent 55%),
      linear-gradient(180deg, #110b2c, #0c0920 55%, #0a0718);
    color: var(--text);
  }
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(20px); animation: rise linear both; animation-timeline: view(); animation-range: entry 0% cover 20%; }
      @keyframes rise { to { opacity: 1; transform: none; } }
      .sessrow__title { display: inline-block; animation: grow linear both; animation-timeline: view(); animation-range: entry 4% cover 34%; transform-origin: left center; }
      @keyframes grow { from { opacity: 0.25; letter-spacing: 0.01em; transform: translateY(12px) scale(0.96); } to { opacity: 1; letter-spacing: -0.02em; transform: none; } }
    }
  }
</style>

<style>
  .back { position: fixed; left: 1rem; bottom: 1rem; z-index: 80; font-family: var(--font-mono); font-size: 0.7rem; color: var(--muted); background: color-mix(in srgb, var(--surface) 82%, transparent); backdrop-filter: blur(8px); border: 1px solid var(--border); padding: 0.4rem 0.7rem; border-radius: 999px; }
  .back:hover { color: var(--accent); }

  /* ON AIR BAR */
  .nowbar { position: fixed; top: 0; left: 0; right: 0; z-index: 70; display: flex; align-items: center; gap: 0.9rem; padding: 0.55rem clamp(1rem, 4vw, 2rem); background: color-mix(in srgb, var(--surface) 80%, transparent); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); font-family: var(--font-mono); font-size: 0.74rem; }
  .nowbar__on { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--accent-2); letter-spacing: 0.12em; font-weight: 600; }
  .nowbar__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-2); box-shadow: 0 0 10px 1px color-mix(in srgb, var(--accent-2) 60%, transparent); animation: throb 1.9s ease-in-out infinite; }
  @keyframes throb { 50% { opacity: 0.35; } }
  .nowbar__wave { width: 60px; --wave-h: 16px; --wave-color: color-mix(in srgb, var(--accent) 80%, transparent); }
  .nowbar__title { color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .nowbar__cta { margin-left: auto; color: var(--accent-ink); background: var(--accent); padding: 0.35rem 0.9rem; border-radius: 999px; letter-spacing: 0.06em; }
  .nowbar__cta:hover { filter: brightness(1.08); }
  @media (max-width: 620px) { .nowbar__wave, .nowbar__title { display: none; } }

  /* HERO */
  .hero { position: relative; min-height: 100dvh; display: flex; flex-direction: column; padding: 3.2rem clamp(1.2rem, 4vw, 3rem) 0; overflow: hidden; }
  .hero::before { content: ''; position: absolute; inset: 0; pointer-events: none; background:
      radial-gradient(48rem 40rem at 72% 14%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 60%),
      radial-gradient(40rem 40rem at 14% 84%, color-mix(in srgb, var(--accent-2) 14%, transparent), transparent 60%); }
  .stars, .stars::after { position: absolute; inset: 0; pointer-events: none; }
  .stars { opacity: 0.9; animation: twinkle 7s ease-in-out infinite; background-image:
      radial-gradient(1.5px 1.5px at 12% 22%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1px 1px at 28% 68%, rgba(255,255,255,0.65), transparent),
      radial-gradient(1.5px 1.5px at 47% 15%, rgba(255,255,255,0.75), transparent),
      radial-gradient(1.5px 1.5px at 63% 52%, rgba(242,120,159,0.85), transparent),
      radial-gradient(1.5px 1.5px at 78% 30%, rgba(255,255,255,0.75), transparent),
      radial-gradient(1px 1px at 88% 72%, rgba(111,216,236,0.85), transparent),
      radial-gradient(1px 1px at 38% 84%, rgba(255,255,255,0.55), transparent),
      radial-gradient(1.5px 1.5px at 70% 88%, rgba(245,176,56,0.75), transparent); }
  .stars::after { content: ''; opacity: 0.7; animation: twinkle 9s ease-in-out 1.4s infinite; background-image:
      radial-gradient(1px 1px at 8% 54%, rgba(255,255,255,0.75), transparent),
      radial-gradient(1px 1px at 33% 34%, rgba(205,185,255,0.75), transparent),
      radial-gradient(1.5px 1.5px at 55% 78%, rgba(255,255,255,0.65), transparent),
      radial-gradient(1px 1px at 72% 18%, rgba(255,255,255,0.65), transparent),
      radial-gradient(1px 1px at 92% 44%, rgba(242,120,159,0.65), transparent),
      radial-gradient(1px 1px at 20% 90%, rgba(111,216,236,0.65), transparent); }
  @keyframes twinkle { 0%, 100% { opacity: 0.4; } 50% { opacity: 0.95; } }
  .hero > * { position: relative; z-index: 1; }
  .hero__nav { display: flex; align-items: center; justify-content: space-between; color: var(--text); }
  .hero__freq { font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.16em; color: var(--accent); }
  .hero__center { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem 0; }
  .hero__kick { font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .hero__title { font-size: clamp(3rem, 10vw, 8rem); font-weight: 600; letter-spacing: -0.04em; line-height: 0.92; margin: 1.3rem 0 0; }
  .hero__title em { font-style: italic; font-weight: 300; color: var(--accent); }
  .hero__sub { margin-top: 1.6rem; max-width: 44ch; color: var(--muted); font-size: 1.12rem; line-height: 1.6; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 2rem; }
  .hero__dial { position: relative; width: min(440px, 82%); height: 14px; margin-top: 2.6rem; background-image: repeating-linear-gradient(90deg, color-mix(in srgb, var(--muted) 60%, transparent) 0 1px, transparent 1px 20px); -webkit-mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent); mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent); }
  .hero__dialknob { position: absolute; top: 50%; left: 50%; width: 11px; height: 11px; margin: -5.5px 0 0 -5.5px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 16px 4px color-mix(in srgb, var(--accent) 48%, transparent); animation: tune 6s ease-in-out infinite; }
  @keyframes tune { 0%, 100% { transform: translateX(-96px); } 50% { transform: translateX(96px); } }
  .hero__marquee { border-top: 1px solid var(--border); overflow: hidden; padding: 1rem 0; }
  .hero__mtrack { display: inline-flex; white-space: nowrap; width: max-content; animation: slide 44s linear infinite; font-size: clamp(1.3rem, 3vw, 2.1rem); font-weight: 300; font-style: italic; color: color-mix(in srgb, var(--text) 48%, transparent); }
  .hero__mtrack span { padding: 0 0.4rem; } .hero__mtrack b { color: var(--accent); padding: 0 1rem; }
  @keyframes slide { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .hero__mtrack { animation: none; } }

  .btn { display: inline-flex; align-items: center; font-weight: 500; font-size: 0.98rem; padding: 0.72rem 1.4rem; border-radius: var(--radius); transition: transform 0.12s ease, filter 0.2s ease, border-color 0.2s ease, background 0.2s ease; }
  .btn--solid { background: var(--accent); color: var(--accent-ink); }
  .btn--solid:hover { filter: brightness(1.08); } .btn--solid:active { transform: translateY(1px) scale(0.99); }
  .btn--ghost { border: 1px solid var(--border); color: var(--text); }
  .btn--ghost:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); }

  .bc__wrap { max-width: 1080px; margin: 0 auto; padding: 0 clamp(1.2rem, 4vw, 3rem); }
  .block { padding: clamp(3.5rem, 8vw, 6rem) 0; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
  .block__h { font-size: clamp(1.9rem, 5vw, 3.1rem); font-weight: 600; letter-spacing: -0.035em; line-height: 1.03; margin-top: 1rem; max-width: 20ch; }
  .block__h em { font-style: italic; font-weight: 300; color: var(--accent-2); }
  .block__lead { margin-top: 1.2rem; max-width: 54ch; color: var(--muted); font-size: 1.08rem; line-height: 1.65; }

  /* CONSTELLATION */
  .orbit { position: relative; width: min(600px, 92vw); aspect-ratio: 1; margin: 3rem auto 0; }
  .sun { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; width: 96px; height: 96px; display: grid; place-items: center; border-radius: 50%; color: var(--accent); background: radial-gradient(circle, color-mix(in srgb, var(--accent) 32%, transparent), transparent 70%); border: 1px dashed color-mix(in srgb, var(--accent) 50%, transparent); }
  .sun::before { content: ''; position: absolute; inset: -35%; z-index: -1; border-radius: 50%; background: radial-gradient(circle, color-mix(in srgb, var(--accent) 24%, transparent), transparent 68%); animation: sunpulse 5s ease-in-out infinite; }
  .ring { position: absolute; inset: 9%; border: 1px dashed color-mix(in srgb, var(--text) 16%, transparent); border-radius: 50%; }
  .planets { list-style: none; margin: 0; padding: 0; position: absolute; inset: 0; }
  /* single self-uprighting orbit: rotate out to radius, then counter-rotate content — one transform, never desyncs */
  .planet { position: absolute; top: 50%; left: 50%; --r: clamp(140px, 34vw, 232px); transform: translate(-50%, -50%) rotate(var(--angle, 0deg)) translateX(var(--r)) rotate(calc(-1 * var(--angle, 0deg))); animation: orbit 130s linear infinite; animation-delay: var(--delay, 0s); }
  .planet__btn { background: none; border: none; padding: 0; cursor: pointer; color: inherit; display: block; }
  .planet__spin { width: 128px; }
  .planet__lift { display: flex; flex-direction: column; align-items: center; gap: 0.55rem; transition: transform 0.4s cubic-bezier(0.34, 1.45, 0.5, 1); will-change: transform; }
  .planet__btn:hover .planet__lift, .planet__btn:focus-visible .planet__lift { transform: scale(1.14) translateY(-6px); }
  .planet__pic { width: 84px; border-radius: 50%; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 12px 34px -12px rgba(0, 0, 0, 0.7); animation: bob 5s ease-in-out infinite; animation-delay: calc(var(--i, 0) * -0.8s); transition: box-shadow 0.35s ease, border-color 0.35s ease; }
  .planet__btn:hover .planet__pic, .planet__btn:focus-visible .planet__pic { border-color: color-mix(in srgb, var(--accent) 65%, transparent); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 42%, transparent), 0 22px 48px -12px rgba(0, 0, 0, 0.85); }
  .planet__name { font-size: 0.98rem; font-weight: 600; text-align: center; transition: color 0.3s ease; }
  .planet__btn:hover .planet__name, .planet__btn:focus-visible .planet__name { color: var(--accent); }
  .planet__role { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-2); }
  /* spotlight: focus the hovered planet, dim the rest */
  .planet { transition: opacity 0.35s ease; }
  .planets:has(.planet__btn:hover) .planet:not(:hover),
  .planets:has(.planet__btn:focus-visible) .planet:not(:focus-within) { opacity: 0.32; }
  @keyframes orbit {
    from { transform: translate(-50%, -50%) rotate(0deg) translateX(var(--r)) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg) translateX(var(--r)) rotate(-360deg); }
  }
  @keyframes bob { 50% { transform: translateY(-7px); } }
  @keyframes sunpulse { 0%, 100% { transform: scale(0.9); opacity: 0.55; } 50% { transform: scale(1.12); opacity: 1; } }
  /* pause only when a planet is actually hovered/focused (not the whole orbit area) so it never freezes abruptly */
  .orbit:has(.planet__btn:hover) .planet, .orbit:focus-within .planet, #crew:has([popover]:popover-open) .planet { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) { .planet, .planet__pic, .sun::before, .stars, .stars::after, .hero__mtrack, .hero__dialknob { animation: none; } }
  @media (max-width: 760px) {
    .orbit { aspect-ratio: auto; width: 100%; }
    .sun, .ring { display: none; }
    .planets { position: static; display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; }
    .planet { position: static; transform: none; animation: none; }
    .planet__spin { width: 100%; }
  }

  /* SOCIAL POPOVER CARD */
  .scard { margin: auto; width: min(340px, 90vw); border: 1px solid var(--border); border-radius: calc(var(--radius) + 2px); background: linear-gradient(165deg, var(--surface-2), var(--surface)); color: var(--text); padding: 1.4rem; box-shadow: 0 40px 90px -40px rgba(0, 0, 0, 0.9); }
  .scard::backdrop { background: rgba(8, 6, 18, 0.6); backdrop-filter: blur(3px); }
  .scard__head { display: flex; align-items: center; gap: 0.9rem; }
  .scard__pic { width: 56px; border-radius: 50%; overflow: hidden; flex: none; }
  .scard__name { font-size: 1.2rem; font-weight: 600; }
  .scard__role { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-2); margin-top: 0.2rem; }
  .scard__blurb { color: var(--muted); font-size: 0.92rem; line-height: 1.55; margin-top: 1rem; }
  .scard__links { list-style: none; padding: 0; margin: 1.2rem 0 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .scard__links a { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--text); border: 1px solid var(--border); border-radius: 999px; padding: 0.4rem 0.8rem; transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease; }
  .scard__links a:hover { border-color: var(--accent); color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); }
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .scard { transition: opacity 0.2s ease, transform 0.2s ease; }
      .scard:popover-open { animation: pop 0.22s cubic-bezier(0.16, 1, 0.3, 1); }
      @keyframes pop { from { opacity: 0; transform: translateY(10px) scale(0.97); } }
    }
  }

  /* SESSIONS (Kinetic list) */
  .sess__head { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: start; }
  .sess__note { justify-self: end; text-align: right; max-width: 34ch; color: var(--muted); line-height: 1.6; }
  .sesslist { list-style: none; padding: 0; margin: 2.5rem 0 0; }
  .sessrow { position: relative; display: grid; grid-template-columns: 5rem 1fr auto; gap: 1.5rem; align-items: baseline; padding: 1.4rem 0; border-top: 1px solid var(--border); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .sessrow:last-child { border-bottom: 1px solid var(--border); }
  .sessrow::after { content: ''; position: absolute; left: -1.1rem; top: 20%; bottom: 20%; width: 3px; border-radius: 2px; background: var(--accent); transform: scaleY(0); transform-origin: center; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .sessrow:hover { transform: translateX(14px); }
  .sessrow:hover::after { transform: scaleY(1); }
  .sessrow:hover .sessrow__title { color: var(--accent); }
  .sessrow__ep { font-family: var(--font-mono); font-size: 0.82rem; color: var(--muted); }
  .sessrow__title { font-size: clamp(1.6rem, 4vw, 2.9rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1; transition: color 0.3s ease; }
  .sessrow.is-next .sessrow__title { color: var(--accent); }
  .sessrow__meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; }
  .sessrow__topic { color: var(--muted); }
  .sessrow__tag { color: var(--accent-2); }
  .sessrow.is-next .sessrow__tag { color: var(--accent); }
  @media (max-width: 720px) {
