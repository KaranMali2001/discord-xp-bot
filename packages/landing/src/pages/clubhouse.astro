<script>
  // Tiny tactile island: nudge each flyer's tilt on pointer-move so the wall
  // feels physical. Purely decorative, fine-pointer + motion-safe only.
  const finePointer = matchMedia('(pointer: fine)').matches;
  const motionOk = !matchMedia('(prefers-reduced-motion: reduce)').matches;
  const wide = matchMedia('(min-width: 641px)').matches;

  if (finePointer && motionOk && wide) {
    const cards = document.querySelectorAll<HTMLElement>('.polaroid, .flyer');
    cards.forEach((card) => {
      card.addEventListener('pointermove', (e) => {
        const r = card.getBoundingClientRect();
        const dx = (e.clientX - r.left) / r.width - 0.5;
        card.style.setProperty('--tilt', `${dx * 3}deg`);
      });
      card.addEventListener('pointerleave', () => {
        card.style.removeProperty('--tilt');
      });
    });
  }
</script>
