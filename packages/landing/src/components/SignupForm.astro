---
// Join form. No backend yet — submitting shows a dummy confirmation state.
// Themed entirely through inherited CSS variables so it matches any concept.
interface Props {
  cta?: string;
  placeholder?: string;
}
const { cta = 'Tune in', placeholder = 'you@domain.dev' } = Astro.props;
---
<form class="signup" novalidate data-signup>
  <div class="signup__row">
    <label class="signup__field">
      <span class="signup__label">Name</span>
      <input type="text" name="name" autocomplete="name" placeholder="First name" required />
    </label>
    <label class="signup__field">
      <span class="signup__label">Email</span>
      <input type="email" name="email" autocomplete="email" placeholder={placeholder} required />
    </label>
  </div>
  <button type="submit" class="signup__btn">{cta}</button>
  <p class="signup__note" data-signup-note aria-live="polite">
    No spam. One reminder before each Friday session.
  </p>
</form>

<style>
  .signup {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    width: 100%;
    max-width: 34rem;
  }
  .signup__row {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 0.75rem;
  }
  .signup__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .signup__label {
    font-family: var(--font-mono, var(--font-geist-mono));
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .signup input {
    font-family: var(--font-display, var(--font-geist));
    font-size: 1rem;
    color: var(--text);
    background: color-mix(in srgb, var(--text) 5%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius, 10px);
    padding: 0.7rem 0.85rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .signup input::placeholder { color: color-mix(in srgb, var(--muted) 75%, transparent); }
  .signup input:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .signup__btn {
    justify-self: start;
    font-family: var(--font-display, var(--font-geist));
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: 0.01em;
    color: var(--accent-ink, #0b0d17);
    background: var(--accent);
    border: none;
    border-radius: var(--radius, 10px);
    padding: 0.75rem 1.6rem;
    cursor: pointer;
    transition: transform 0.12s ease, filter 0.2s ease;
  }
  .signup__btn:hover { filter: brightness(1.08); }
  .signup__btn:active { transform: translateY(1px) scale(0.99); }
  .signup__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .signup__note {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .signup[data-sent] .signup__row,
  .signup[data-sent] .signup__btn { display: none; }
  .signup[data-sent] .signup__note { color: var(--accent); font-weight: 500; }
  @media (max-width: 520px) {
    .signup__row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Progressive enhancement only: the form is usable markup without JS.
  document.querySelectorAll<HTMLFormElement>('form[data-signup]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = form.querySelector<HTMLInputElement>('input[name="email"]');
      const name = form.querySelector<HTMLInputElement>('input[name="name"]');
      const note = form.querySelector<HTMLParagraphElement>('[data-signup-note]');
      if (!email?.value || !name?.value || !email.checkValidity()) {
        email?.reportValidity();
        name?.reportValidity();
        return;
      }
      form.setAttribute('data-sent', '');
      if (note) note.textContent = `You're on the list, ${name.value.split(' ')[0]}. See you Friday.`;
    });
  });
</script>
