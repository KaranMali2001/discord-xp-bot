---
// Pure-CSS animated audio waveform. Sizing + color via CSS variables:
// --wave-h, --wave-gap, --wave-color, --wave-speed.
interface Props {
  bars?: number;
  class?: string;
}
const { bars = 32, class: className = '' } = Astro.props;
---
<span class:list={['wave', className]} aria-hidden="true">
  {Array.from({ length: bars }).map((_, i) => <i style={`--i:${i}`}></i>)}
</span>

<style>
  .wave {
    display: flex;
    align-items: center;
    gap: var(--wave-gap, 3px);
    height: var(--wave-h, 32px);
    width: 100%;
  }
  .wave i {
    flex: 1;
    min-width: 2px;
    border-radius: 2px;
    background: var(--wave-color, var(--accent));
    height: 35%;
    animation: wavepulse var(--wave-speed, 1.2s) ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.063s);
  }
  @keyframes wavepulse {
    0%, 100% { height: 20%; }
    50% { height: 92%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wave i { animation: none; height: 52%; }
  }
</style>
