---
// The Tech Talks mark: a monoline broadcast microphone paired with a </> code
// bubble. Strokes use currentColor so each concept tints it via `color`.
interface Props {
  size?: number;
  wordmark?: boolean;
  class?: string;
}
const { size = 30, wordmark = true, class: className = '' } = Astro.props;
---
<span class:list={['logo', className]}>
  <svg
    class="logo__mark"
    width={size}
    height={size}
    viewBox="0 0 72 64"
    fill="none"
    stroke="currentColor"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <!-- mic capsule -->
    <rect x="24" y="8" width="18" height="30" rx="9" />
    <line x1="28" y1="16" x2="38" y2="16" />
    <line x1="28" y1="22" x2="38" y2="22" />
    <line x1="28" y1="28" x2="38" y2="28" />
    <!-- yoke + stand -->
    <path d="M18 30 v2 a15 15 0 0 0 30 0 v-2" />
    <line x1="33" y1="47" x2="33" y2="55" />
    <line x1="25" y1="55" x2="41" y2="55" />
    <!-- code bubble -->
    <rect x="45" y="6" width="24" height="17" rx="4" />
    <path d="M53 10 L49.5 14 L53 18" />
    <path d="M59.5 9 L55.5 19" />
    <path d="M61 10 L64.5 14 L61 18" />
  </svg>
  {wordmark && <span class="logo__word">TECH TALKS</span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: inherit;
  }
  .logo__mark {
    flex: none;
    display: block;
  }
  .logo__word {
    font-family: var(--font-display, var(--font-geist));
    font-weight: 500;
    letter-spacing: 0.34em;
    font-size: 0.9rem;
    text-transform: uppercase;
    padding-left: 0.1em; /* optically balance the wide tracking */
    white-space: nowrap;
  }
</style>
